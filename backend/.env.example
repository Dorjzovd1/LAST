# Removable Evidence Analyzer - backend tohirgoo
# Energ failiig .env ruu huulj zasna.

# SQLite database file
REA_DATABASE_URL=sqlite:///./data/rea.db

# Ajliin haltsuud (recovered files, exports)
REA_DATA_DIR=./data
REA_RECOVERED_DIR=./data/recovered
REA_EXPORT_DIR=./data/exports

# Forensic CLI oldohgui ued mock mode-d shiljih eseh (1=zovshooron)
REA_ALLOW_MOCK=1

# CORS-d zovshoorson frontend origin
REA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
